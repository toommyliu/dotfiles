{
  "profiles": [
    {
      "complex_modifications": {
        "rules": [
          {
            "description": "Caps Lock → Hyper Key (⌃⌥⇧⌘) / Caps Lock if alone",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "caps_lock",
                  "modifiers": { "optional": ["any"] }
                },
                "to": [
