                    "file_paths": [
                      "^/Applications/Parallels Desktop\\.app/",
                      "^/Users/[^/]+/Applications \\(Parallels\\)/",
                      "^/Users/[^/]+/Parallels/.*\\.pvm/"
                    ]
                  }
                ],
                "parameters": {
                  "basic.to_if_alone_timeout_milliseconds": 200
                }
              }
            ]
          }
        ]
      },
      "name": "Default profile",
      "selected": true,
